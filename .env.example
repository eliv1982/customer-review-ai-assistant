# Скопируйте в файл .env и заполните значения. Файл .env в репозиторий не коммитить.

# Токен Telegram Bot API от @BotFather (обязателен для python main.py с long polling)
TELEGRAM_BOT_TOKEN=

# Ключ API OpenAI (обязателен для анализа отзывов в боте и для smoke): https://platform.openai.com/
OPENAI_API_KEY=

# Локальные smoke test (CSV, отчёт, KB, process_review) перед ботом — true / 1 / yes / on
RUN_SMOKE_TESTS=

# Путь к файлу базы SQLite (можно относительно корня проекта)
DATABASE_PATH=data/reviews.db

# Модель чата для классификации и черновиков ответов
OPENAI_MODEL=gpt-4o-mini

# Уровень логов: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
